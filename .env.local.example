# URL of the dedicated Express + Socket.io backend.
# Used server-side by the app/api proxy routes only (not exposed to the browser),
# so it is intentionally NOT prefixed with NEXT_PUBLIC_.
BACKEND_URL=http://localhost:4000

# NOTE: MONGODB_URI and the LLM provider keys (GEMINI_API_KEY, OPENROUTER_API_KEY,
# XAI_API_KEY) have moved to the backend — see backend/.env.local.example.
